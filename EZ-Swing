<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EZ-Swing</title>

<style>
body {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  background: #f5f7f6;
  color: #1a1a1a;
}

.container {
  width: 90%;
  max-width: 1200px;
  margin: auto;
}

header {
  background: white;
  padding: 15px 0;
  border-bottom: 1px solid #eee;
}

.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo img {
  height: 50px;
}

.btn {
  background: #0b5d3b;
  color: white;
  padding: 12px 24px;
  border: none;
  border-radius: 6px;
  cursor: pointer;
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80px 0;
  gap: 40px;
}

.hero-text {
  max-width: 500px;
}

.hero-text h1 {
  font-size: 48px;
  color: #0b5d3b;
}

.hero-text p {
  font-size: 18px;
  margin: 20px 0;
}

.hero img {
  max-width: 450px;
  border-radius: 10px;
}

.section {
  padding: 80px 0;
  background: white;
}

.section.alt {
  background: #eef3f1;
}

.section h2 {
  text-align: center;
  color: #0b5d3b;
  margin-bottom: 40px;
}

.features {
  display: flex;
  gap: 30px;
  text-align: center;
}

.feature {
  flex: 1;
}

.feature h3 {
  margin-bottom: 10px;
}

.infographic {
  max-width: 100%;
  border-radius: 12px;
  display: block;
  margin: auto;
}

footer {
  background: #0b5d3b;
  color: white;
  text-align: center;
  padding: 30px;
}

@media (max-width: 768px) {
  .hero {
    flex-direction: column;
    text-align: center;
  }

  .features {
    flex-direction: column;
  }
}
</style>
</head>

<body>

<header>
  <div class="container nav">
    <div class="logo">
      <img src="logo.png" alt="EZ Swing Logo">
    </div>
    <button class="btn">Contact</button>
  </div>
</header>

<section class="hero container">
  <div class="hero-text">
    <h1>Swing Made Accessible</h1>
    <p>
      EZ-Swing is an adaptive golf sleeve designed to help individuals
      with hand injuries or disabilities swing with confidence.
    </p>
    <button class="btn">Learn More</button>
  </div>

  <!-- YOUR PRODUCT IMAGE -->
  <img src="product.jpg" alt="EZ Swing Sleeve">
</section>

<section class="section alt">
  <div class="container">
    <h2>Why EZ-Swing?</h2>

    <div class="features">
      <div class="feature">
        <h3>Secure Grip</h3>
        <p>Velcro straps ensure a tight and stable hold.</p>
      </div>

      <div class="feature">
        <h3>Comfortable Fit</h3>
        <p>Designed for long-lasting comfort and ease.</p>
      </div>

      <div class="feature">
        <h3>Universal Design</h3>
        <p>Fits all standard golf club grips.</p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2>See How It Works</h2>

    <!-- YOUR INFOGRAPHIC IMAGE -->
    <img src="infographic.jpg" class="infographic" alt="EZ Swing Info">
  </div>
</section>

<section class="section alt">
  <div class="container" style="text-align:center;">
    <h2>Making Golf Accessible</h2>
    <p style="max-width:700px; margin:auto;">
      EZ-Swing restores independence and brings the joy of golf back
      to those who need it most.
    </p>
  </div>
</section>

<footer>
  <p>© 2026 EZ-Swing. All rights reserved.</p>
</footer>

</body>
</html>